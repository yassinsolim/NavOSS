{
  "expo": {
    "name": "NavOSS",
    "slug": "navoss",
    "version": "0.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "navoss",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "org.navoss.mobile",
      "icon": "./assets/expo.icon",
      "supportsTablet": false,
      "infoPlist": {
        "EXDevMenuShowFloatingActionButton": false,
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "NSLocalNetworkUsageDescription": "NavOSS connects to your local development server while you test the app."
      }
    },
    "android": {
      "package": "org.navoss.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#F5C84C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F7F7F2"
        }
      ],
      "@maplibre/maplibre-react-native",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "NavOSS uses your location to center the map and prepare navigation.",
          "isIosBackgroundLocationEnabled": false,
          "isAndroidBackgroundLocationEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
