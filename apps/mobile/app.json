{
  "expo": {
    "name": "NavOSS",
    "slug": "navoss",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "navoss",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "org.navoss.mobile",
      "buildNumber": "1",
      "icon": "./assets/expo.icon",
      "supportsTablet": false,
      "infoPlist": {
        "EXDevMenuShowFloatingActionButton": false,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "org.navoss.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#1B2526",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1B2526",
          "image": "./assets/images/android-icon-foreground.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      "@maplibre/maplibre-react-native",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "NavOSS uses your location to center the map and prepare navigation.",
          "isIosBackgroundLocationEnabled": false,
          "isAndroidBackgroundLocationEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2a95b51d-dd23-431b-b941-fd80c13aadf5"
      }
    },
    "owner": "yassinsolim"
  }
}
