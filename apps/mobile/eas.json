{
  "cli": {
    "appVersionSource": "remote",
    "version": ">= 16.0.0"
  },
  "build": {
    "base": {
      "node": "24.18.0"
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "extends": "base"
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "extends": "base"
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "env": {
        "NAVOSS_CARPLAY_ENABLED": "0",
        "NAVOSS_CARPLAY_ENTITLEMENT_ENABLED": "0"
      },
      "extends": "base"
    },
    "production-carplay": {
      "autoIncrement": true,
      "environment": "production",
      "env": {
        "NAVOSS_CARPLAY_ENABLED": "1",
        "NAVOSS_CARPLAY_ENTITLEMENT_ENABLED": "1"
      },
      "extends": "base"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6792619727"
      }
    },
    "production-carplay": {
      "ios": {
        "ascAppId": "6792619727"
      }
    }
  }
}
