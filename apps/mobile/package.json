{
  "name": "@navoss/mobile",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "license": "MPL-2.0",
  "dependencies": {
    "@expo-google-fonts/atkinson-hyperlegible-next": "0.4.1",
    "@expo/ui": "~57.0.4",
    "@maplibre/maplibre-react-native": "11.3.6",
    "@navoss/contracts": "workspace:*",
    "expo": "~57.0.4",
    "expo-constants": "~57.0.3",
    "expo-dev-client": "~57.0.5",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-location": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@types/geojson": "7946.0.16",
    "@types/react": "~19.2.2",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "scripts": {
    "build": "expo export --platform ios --output-dir dist",
    "build:release": "node ./scripts/validate-release-env.mjs && expo export --platform ios --output-dir dist-release",
    "check": "tsc -p tsconfig.json --noEmit",
    "eas-build-pre-install": "node ./scripts/validate-release-env.mjs",
    "start": "expo start --dev-client",
    "start:simulator": "EXPO_PUBLIC_API_URL=http://127.0.0.1:3001 expo start --dev-client --localhost",
    "android": "expo run:android",
    "ios": "DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer EXPO_PUBLIC_API_URL=http://127.0.0.1:3001 expo run:ios",
    "ios:device": "DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer expo run:ios --device",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "vitest run",
    "test:native:ios": "swift test --package-path modules/navoss-navigation",
    "test:e2e:ios": "sh ./scripts/run-maestro-ios.sh ../../.maestro/about-privacy.yaml && sh ./scripts/run-maestro-ios.sh ../../.maestro/search-calgary-tower.yaml && sh ./scripts/run-maestro-ios.sh ../../.maestro/route-to-airport.yaml && sh ./scripts/run-maestro-ios.sh ../../.maestro/route-to-university-avoid-highways.yaml && sh ./scripts/run-reroute-maestro-ios.sh && sh ./scripts/run-arrival-maestro-ios.sh && sh ./scripts/run-safety-camera-maestro-ios.sh",
    "test:e2e:about:ios": "sh ./scripts/run-maestro-ios.sh ../../.maestro/about-privacy.yaml",
    "test:e2e:arrival:ios": "sh ./scripts/run-arrival-maestro-ios.sh",
    "test:e2e:avoid-highways:ios": "sh ./scripts/run-maestro-ios.sh ../../.maestro/route-to-university-avoid-highways.yaml",
    "test:e2e:reroute:ios": "sh ./scripts/run-reroute-maestro-ios.sh",
    "test:e2e:route:ios": "sh ./scripts/run-maestro-ios.sh ../../.maestro/route-to-airport.yaml",
    "test:e2e:safety-cameras:ios": "sh ./scripts/run-safety-camera-maestro-ios.sh",
    "test:simulate:ios": "sh ./scripts/run-maestro-ios.sh ../../.maestro/start-airport-simulation.yaml && node ./scripts/replay-route-ios.mjs",
    "validate:release": "node ./scripts/validate-release-env.mjs"
  },
  "private": true
}
