{
  "name": "navoss",
  "version": "0.0.0",
  "private": true,
  "description": "Privacy-first, open-source navigation for Calgary.",
  "license": "SEE LICENSES/README.md",
  "homepage": "https://github.com/yassinsolim/NavOSS#readme",
  "bugs": {
    "url": "https://github.com/yassinsolim/NavOSS/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yassinsolim/NavOSS.git"
  },
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": "11.13.0"
  },
  "scripts": {
